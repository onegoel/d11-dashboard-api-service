// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String

  seasonsPlayed SeasonUser[]
  wonSeasons    Season[]     @relation("SeasonWinner")
}

model Season {
  id           Int    @id @default(autoincrement())
  name         String
  year         Int
  winnerUserId Int?

  winnerUser User? @relation("SeasonWinner", fields: [winnerUserId], references: [id])

  seasonUsers SeasonUser[]
  matches     Match[]
}

model SeasonUser {
  id          Int    @id @default(autoincrement())
  seasonId    Int
  userId      Int
  teamName    String
  finalRank   Int?
  totalPoints Int?

  season Season @relation(fields: [seasonId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  scores    Score[]
  chipPlays ChipPlay[]

  @@unique([seasonId, userId])
}

model Team {
  id        Int    @id @default(autoincrement())
  name      String
  shortCode String

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id        Int      @id @default(autoincrement())
  seasonId  Int
  matchNo   Int
  matchDate DateTime

  homeTeamId Int
  awayTeamId Int

  season Season @relation(fields: [seasonId], references: [id])

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  scores    Score[]
  chipPlays ChipPlay[]

  @@unique([seasonId, matchNo])
}

model ChipType {
  id               Int     @id @default(autoincrement())
  name             String
  description      String?
  multiplier       Float
  maxUsesPerSeason Int

  chipPlays ChipPlay[]
}

model ChipPlay {
  id           Int      @id @default(autoincrement())
  seasonUserId Int
  chipTypeId   Int
  matchId      Int
  playedAt     DateTime @default(now())

  seasonUser SeasonUser @relation(fields: [seasonUserId], references: [id])
  chipType   ChipType   @relation(fields: [chipTypeId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])

  score Score?
}

model Score {
  id            Int  @id @default(autoincrement())
  seasonUserId  Int
  matchId       Int
  points        Int
  rank          Int
  chipPlayId    Int? @unique

  seasonUser SeasonUser @relation(fields: [seasonUserId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])
  chipPlay   ChipPlay?  @relation(fields: [chipPlayId], references: [id])

  @@unique([seasonUserId, matchId])
}