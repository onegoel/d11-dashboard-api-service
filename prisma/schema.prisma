generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

model User {
  id   Int    @id @default(autoincrement())
  last_name String
  first_name String
  user_name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonsPlayed SeasonUser[]
  wonSeasons    Season[]     @relation("SeasonWinner")
}

model Season {
  id           Int     @id @default(autoincrement())
  name         String
  year         Int
  isActive     Boolean @default(true)

  startDate DateTime?
  endDate   DateTime?

  winnerUserId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  winnerUser User? @relation("SeasonWinner", fields: [winnerUserId], references: [id])

  seasonUsers SeasonUser[]
  matches     Match[]
}

model SeasonUser {
  id          String @id @default(uuid())
  seasonId    Int
  userId      Int
  teamName    String
  finalRank   Int?
  totalPoints Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  scores      Score[]
  chipPlays   ChipPlay[]
  playerPicks PlayerPick[]

  @@unique([seasonId, userId])
  @@index([seasonId])
}

model Team {
  id        String @id @default(uuid())
  name      String
  shortCode String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id        String   @id @default(uuid())
  seasonId  Int
  matchNo   Int
  matchDate DateTime
  status    MatchStatus @default(SCHEDULED)

  homeTeamId String
  awayTeamId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id])

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  scores    Score[]
  chipPlays ChipPlay[]
  picks     PlayerPick[]

  @@unique([seasonId, matchNo])
  @@index([seasonId])
  @@index([matchDate])
}

model ChipType {
  id               Int     @id @default(autoincrement())
  name             String
  description      String?
  multiplier       Float
  maxUsesPerSeason Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chipPlays ChipPlay[]
}

model ChipPlay {
  id           String   @id @default(uuid())
  seasonUserId String
  chipTypeId   Int
  matchId      String
  playedAt     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonUser SeasonUser @relation(fields: [seasonUserId], references: [id])
  chipType   ChipType   @relation(fields: [chipTypeId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])

  score Score?
}

model Score {
  id           String  @id @default(uuid())
  seasonUserId String
  matchId      String

  points Int
  rank   Int

  captainPoints Int?
  benchPoints   Int?

  chipPlayId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonUser SeasonUser @relation(fields: [seasonUserId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])
  chipPlay   ChipPlay?  @relation(fields: [chipPlayId], references: [id])

  @@unique([seasonUserId, matchId])
  @@index([matchId])
  @@index([seasonUserId])
}

model PlayerPick {
  id           String @id @default(uuid())
  seasonUserId String
  matchId      String

  playerName String
  isCaptain  Boolean @default(false)

  points Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonUser SeasonUser @relation(fields: [seasonUserId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])

  @@index([seasonUserId])
  @@index([matchId])
}