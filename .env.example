PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/d11_dashboard
CORS_ORIGIN=http://localhost:5173,https://your-ui-domain.pages.dev
BEST_N_DROP_COUNT=5
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: CricAPI auto-sync on deploy (runs once safely when fully configured)
# Pattern for tournament-specific config:
#   CRICAPI_<TOURNAMENT>_SERIES_ID=<uuid from CricAPI>
#   CRICAPI_<TOURNAMENT>_DB_SEASON_ID=<local season ID>
# Examples: CRICAPI_IPL_2026_SERIES_ID, CRICAPI_IPL_2027_SERIES_ID, CRICAPI_PKL_2026_SERIES_ID
# Generic fallback keys also supported: CRICAPI_SERIES_ID, CRICAPI_DB_SEASON_ID

CRICAPI_API_KEY=
# Score source mode for live-score ingestion:
#   auto -> production uses live CricAPI, non-production uses local mock
#   mock -> always use local mock file
#   live -> always call live CricAPI
CRICAPI_SCORE_SOURCE=auto

# Poller switch:
#   true  -> scheduler polls and persists score snapshots
#   false -> no background polling
# Default is production-only (true in prod, false otherwise)
CRICAPI_ENABLE_SCORE_POLLER=

# Mock fallback switch for GET /matches/:id/score when DB snapshot is empty:
#   true  -> return mock score payload immediately (useful for UI iteration)
#   false -> do not synthesize score data
# Default: false
CRICAPI_ENABLE_MOCK_SCORE_FALLBACK=false

# IPL 2026 Season (example)
# CRICAPI_IPL_2026_SERIES_ID=
# CRICAPI_IPL_2026_DB_SEASON_ID=1